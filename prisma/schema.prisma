// S.T. Dupont online store — Prisma schema
// Docs: https://pris.ly/d/prisma-schema
//
// Money is stored as integer minor units (cents) to avoid float rounding.
// Card data is NEVER stored here — payments live only as Stripe references.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  CUSTOMER
  ADMIN
  LOJA_LIS // boutique Lisboa — edits only Stk LIS in /admin/variants
  LOJA_VNG // boutique V. N. de Gaia — edits only Stk VNG
}

// DISPONIVEL    — visible on the site, normal flow
// INDISPONIVEL  — visible, badged "Indisponível", Pedir-Informação disabled
// DESCONTINUADO — hidden from /c/ and /p/ entirely
enum VariantStatus {
  DISPONIVEL
  INDISPONIVEL
  DESCONTINUADO
}

enum OrderStatus {
  PENDING // created, awaiting payment
  PAID // Stripe confirmed payment
  FULFILLING // being prepared
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  REQUIRES_PAYMENT
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ----- In-store operations (internal POS — mirrors the ECI control Excel) -----

// Which boutique a sale / movement / operator belongs to. Matches the
// stockLis / stockVng split and the LOJA_LIS / LOJA_VNG staff roles.
enum Boutique {
  LIS // Lisboa
  VNG // V. N. de Gaia
}

// The Excel's V/D column: a sale (venda) or a return (devolução).
enum SaleType {
  VENDA
  DEVOLUCAO
}

// Repair-ticket lifecycle (Excel "Estado [Ir atualizando]"). Free text in the
// sheet ("Resolvido", "Em curso", …) is normalised to these states; the UI
// shows PT labels.
enum RepairStatus {
  ABERTO // acabou de dar entrada
  EM_ANALISE // em análise em loja
  EM_ESPANHA // enviado para o técnico (Espanha)
  ORCAMENTO_ENVIADO // orçamento comunicado, a aguardar resposta
  A_AGUARDAR_CLIENTE // aguarda levantamento / decisão do cliente
  RESOLVIDO // concluído / entregue
}

// Every stock-affecting event. Theoretical stock for a variant in a boutique =
// SUM(StockMovement.quantity) over these, exactly like the Excel's DB sheet
// (initial + entries/exits − sales − reservas − danificados). quantity is
// SIGNED: positive increases stock, negative decreases it.
enum MovementType {
  STOCK_INICIAL // opening balance load
  ENTRADA // goods received (Ent)
  SAIDA // goods out (Sai)
  TRANSFER_IN // received from the other boutique / warehouse
  TRANSFER_OUT // sent to the other boutique / warehouse
  VENDA // sold (created from a SaleItem)
  DEVOLUCAO // customer return (reverses a sale)
  RESERVA // held for a client (Reservas)
  DANIFICADO // damaged / warranty pull ((Danificados))
  AJUSTE // manual correction
}

// ---------------------------------------------------------------------------
// Auth (Auth.js / NextAuth-compatible) + users
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String? // null for OAuth-only accounts
  role          UserRole  @default(CUSTOMER)

  accounts  Account[]
  sessions  Session[]
  addresses Address[]
  cart      Cart?
  orders    Order[]
  wishlist  WishlistItem[]
  adminActions AdminAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  fullName   String
  line1      String
  line2      String?
  city       String
  region     String?
  postalCode String
  country    String // ISO 3166-1 alpha-2
  phone      String?
  isDefault  Boolean @default(false)

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Catalog: Product (concept) -> ProductVariant (sellable SKU)
// ---------------------------------------------------------------------------

// Localized text fields hold { "pt": "...", "en": "..." } as JSON so DB
// content stays bilingual (matches the Localized shape used in the UI).
model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      Json // Localized
  tagline   Json // Localized
  history   Json? // Localized — brief heritage of the category/craft
  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        Json // Localized
  description Json // Localized
  history     Json? // Localized — brief heritage of the line
  collection  String
  image       String? // /products/<file> or CDN URL; null -> placeholder
  categoryId  String
  featured    Boolean @default(false) // surfaced in "Novidades"
  active      Boolean @default(true)
  // Denormalised hit counter — incremented on each PDP impression. Drives
  // the "Most viewed" carousel and the admin analytics panel. The
  // ProductView table below holds the per-impression rows for richer
  // reporting (time-series, traffic source) when admin needs to drill in.
  viewCount   Int     @default(0)

  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  wishlistItems WishlistItem[]
  views    ProductView[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([active])
  @@index([viewCount])
}

// One row per PDP impression. The PDP fires a small POST after mount;
// this table backs admin analytics (counts over time, popular days,
// per-product trends). Anonymous — no userId, no IP — so privacy stays
// clean. The denormalised Product.viewCount above mirrors COUNT(*) for
// fast catalogue sorting without touching this table.
model ProductView {
  id        String   @id @default(cuid())
  productId String
  viewedAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([viewedAt])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  sku           String   @unique
  name          Json // Localized — e.g. { pt: "Paládio", en: "Palladium" }
  // Optional per-colourway override of the parent Product.description.
  // Set when a single colourway has its own copy (special edition, limited
  // run, finish-specific story). Null = inherit from Product. Localized
  // shape { pt, en } same as Product.description.
  description   Json?
  attributes    Json     @default("{}") // { finish: "palladium", color: "black" }
  priceCents    Int
  currency      String   @default("EUR")
  // Total stock — application keeps this == stockLis + stockVng on
  // every write (manual edit + Excel upload). Kept as a stored column
  // so existing queries (catalogue card, low-stock KPI) don't have to
  // recompute on every read.
  stock         Int      @default(0)
  stockLis      Int      @default(0) // boutique Lisboa
  stockVng      Int      @default(0) // boutique V. N. de Gaia
  images        String[] @default([]) // ordered image URLs (CDN)
  stripePriceId String? // Stripe Price id, set when synced
  active        Boolean  @default(true)
  // Lifecycle state — DISPONIVEL by default. INDISPONIVEL shows on site
  // with a badge + disabled Pedir-Informação; DESCONTINUADO hides
  // entirely. `active` stays as a legacy flag (already used by some
  // queries) — gradually phased out in favour of `status`.
  status        VariantStatus @default(DISPONIVEL)
  // ----- ERP-import fields (filled from the daily Starbrands Excel) -----
  // EAN / barcode — unique per SKU when present. Indexed for fast
  // scanner lookups in the admin panel.
  ean                  String?   @unique
  // When the current priceCents took effect. Optional — for backwards
  // compat with rows imported before the column existed.
  pvpStartDate         DateTime?
  // Active promotional price in cents (overrides priceCents in the UI
  // while the promo window is open). null = no promo on this variant.
  promoPriceCents      Int?
  promoStartDate       DateTime?
  promoEndDate         DateTime?

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems      CartItem[]
  orderItems     OrderItem[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([active])
  @@index([status])
  @@index([ean])
  @@index([promoEndDate])
}

// Brute-force shield for /admin/login. Every credentials authorize
// attempt writes one row (success or failure). Before accepting an
// auth attempt we count failures for the given email within the last
// LOCKOUT_WINDOW_MIN; once the threshold is hit the email is locked
// out for LOCKOUT_DURATION_MIN. Successful logins clear the failure
// count for that email.
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  success   Boolean
  ip        String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([createdAt])
}

// Audit trail for every write the admin panel performs — manual edits
// in /admin/variants AND bulk uploads. Stores the diff as JSON so the
// admin can review/revert later. userId is the User.id of the admin
// who triggered the action; nullable so seed / migration writes don't
// fail.
model AdminAction {
  id        String   @id @default(cuid())
  userId    String?
  // entityType: VARIANT | PRODUCT | PROMO | UPLOAD_BATCH
  // action:    UPDATE | CREATE | DELETE | UPLOAD
  entityType String
  action     String
  entityId   String? // e.g. variant sku or product slug
  before     Json?   // snapshot of changed fields before the write
  after      Json?   // snapshot after the write
  note       String? // optional human-readable summary
  // Groups all per-row writes from one Excel upload under a single id.
  // The UPLOAD_BATCH summary row shares this id with every VARIANT /
  // PROMO row produced by the same upload, so the audit viewer can
  // render ONE collapsible card per batch with every child change
  // listed inside. Null for inline edits made via /admin/variants.
  batchId    String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([batchId])
}

// ---------------------------------------------------------------------------
// Cart
// ---------------------------------------------------------------------------

model Cart {
  id     String     @id @default(cuid())
  userId String     @unique
  items  CartItem[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int    @default(1)

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, variantId])
  @@index([variantId])
}

// ---------------------------------------------------------------------------
// Orders — OrderItem snapshots the variant at purchase time
// ---------------------------------------------------------------------------

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique // human-friendly, e.g. STD-000123
  userId            String
  status            OrderStatus @default(PENDING)
  currency          String      @default("EUR")
  subtotalCents     Int
  taxCents          Int         @default(0) // from Stripe Tax
  shippingCents     Int         @default(0)
  totalCents        Int
  shippingAddressId String?
  billingAddressId  String?

  user            User        @relation(fields: [userId], references: [id])
  shippingAddress Address?    @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address?    @relation("BillingAddress", fields: [billingAddressId], references: [id])
  items           OrderItem[]
  payment         Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  variantId    String?
  // Snapshots — preserved even if the variant later changes or is deleted
  nameSnapshot String
  skuSnapshot  String
  priceCents   Int
  quantity     Int

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Payment {
  id                    String        @id @default(cuid())
  orderId               String        @unique
  provider              String        @default("stripe")
  stripePaymentIntentId String?       @unique
  stripeCheckoutId      String?       @unique
  status                PaymentStatus @default(REQUIRES_PAYMENT)
  amountCents           Int
  currency              String        @default("EUR")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// In-store operations (internal POS) — replaces the ECI control Excel.
// Money is integer cents. Two derived amounts mirror the Excel: net = gross /
// 1.23 (PT VAT 23%), and the ECI concession commission = net * 0.19. These
// factors live in lib as constants so a rate change is one edit.
// ---------------------------------------------------------------------------

// Salespeople — the Excel "Operadores" sheet (PR, MA, CD, LR, AC, JM). The
// store login is shared, so the operator is chosen per sale, not derived from
// the session. Each belongs to one boutique.
model Operator {
  id               String    @id @default(cuid())
  initials         String // PR, MA, …
  name             String?
  eciCode          String? // ECI employee number
  boutique         Boutique
  monthlyGoalCents Int? // optional monthly sales target
  active           Boolean   @default(true)

  sales     Sale[]
  movements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([boutique, initials])
  @@index([boutique])
}

// One transaction (a basket) — groups its SaleItem lines. The Excel is
// line-per-row (Mov_POS_Loja); we group into a sale so the terminal can ring
// up several items at once. Date/time are system-stamped (soldAt).
model Sale {
  id                 String   @id @default(cuid())
  boutique           Boutique
  operatorId         String
  type               SaleType @default(VENDA)
  soldAt             DateTime @default(now())
  // Totals denormalised from items for fast reporting (all cents).
  grossCents         Int      @default(0) // Σ ValorVend (incl. VAT)
  netCents           Int      @default(0) // Σ V.Rec (gross / 1.23, ex-VAT)
  eciCommissionCents Int      @default(0) // netCents * 0.19 (ECI concession fee)
  note               String?
  // For a DEVOLUCAO, the original sale being reversed (optional).
  originalSaleId     String?

  operator     Operator   @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  originalSale Sale?      @relation("SaleReturns", fields: [originalSaleId], references: [id], onDelete: SetNull)
  returns      Sale[]     @relation("SaleReturns")
  items        SaleItem[]

  createdAt DateTime @default(now())

  @@index([boutique, soldAt])
  @@index([operatorId])
  @@index([soldAt])
  @@index([type])
}

// A sale line — one row of Mov_POS_Loja. Snapshots sku/desc/price/brand (like
// OrderItem) so the record is stable even if the catalogue changes later.
model SaleItem {
  id             String  @id @default(cuid())
  saleId         String
  variantId      String? // link to our catalogue (null if EAN not in catalogue)
  sku            String
  ean            String?
  descSnapshot   String
  brand          String? // Marca
  quantity       Int
  unitPriceCents Int // PVP at time of sale
  discountPct    Float   @default(0) // Desc % as 0..1
  grossCents     Int // quantity * unitPriceCents * (1 - discountPct)
  netCents       Int // grossCents / 1.23

  sale    Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([variantId])
  @@index([sku])
}

// The stock ledger — every event that changes stock, per boutique. Theoretical
// stock = SUM(quantity) grouped by (variantId, boutique); the variant's
// stockLis / stockVng columns are kept as a cache of those sums (recomputed on
// each write, exactly like the existing stock = stockLis + stockVng pattern).
model StockMovement {
  id         String       @id @default(cuid())
  boutique   Boutique
  variantId  String?
  sku        String
  ean        String?
  type       MovementType
  quantity   Int // SIGNED: +in / -out
  operatorId String?
  saleItemId String? // set when the movement came from a sale line
  note       String?
  movedAt    DateTime     @default(now())

  variant  ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  operator Operator?       @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([boutique, variantId])
  @@index([variantId])
  @@index([movedAt])
  @@index([type])
}

// After-sales / repair ticket — mirrors the Excel "Reparações" sheet. The
// first-visit date is system-stamped on creation (data automática); every
// other field is filled in and kept up to date as the case progresses (the
// sheet's "Ir atualizando" columns). Column order in the admin table follows
// the Excel: 1ª Visita · Staff · Estado · Cliente · Ref. · Assunto ·
// Atualizações · Último contacto (data/staff/via/obs.) · Outras obs. · Tlm ·
// Outros contactos.
model Repair {
  id           String       @id @default(cuid())
  boutique     Boutique     @default(LIS) // qual loja acompanha o processo
  // 1ª_Visita — data automática em novos processos (default now()); nullable
  // porque o histórico importado tem linhas com data desconhecida ("??").
  firstVisitAt DateTime?    @default(now())
  staff        String // Staff — iniciais do operador (PR, MA, …)
  status       RepairStatus @default(ABERTO) // Estado [Ir atualizando]
  customerName String // Cli_Nome
  reference    String // Ref. — artigo / referência
  subject      String // Assunto — descrição do problema/pedido
  updates      String? // Atualizações — notas do processo
  // Último_Contato — data & staff / via / observação
  lastContactAt    DateTime? // Último_Contato_Data
  lastContactStaff String? // & Staff que fez o contacto
  lastContactVia   String? // Último_Contato (Whatsapp, Chamada tlf., Em loja, E-mail, SMS…)
  lastContactNote  String? // Último_Contato_Obs.
  otherObs         String? // Outras_Obs._Contatos (ex.: "Não ligar! Enviar msg")
  phone            String? // Tlm_WhatsApp
  otherContacts    String? // Outros_Contatos (e-mail / outro telefone)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boutique, firstVisitAt])
  @@index([status])
  @@index([firstVisitAt])
}
